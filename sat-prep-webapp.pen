                                    },
                                    {
                                      "type": "text",
                                      "id": "HXecS",
                                      "fill": "#475569",
                                      "content": "Correct because two independent clauses can be joined with a comma and the coordinating conjunction and.",
                                      "fontFamily": "DM Sans",
                                      "fontSize": 14,
                                      "fontWeight": "normal"
                                    }
                                  ]
                                },
